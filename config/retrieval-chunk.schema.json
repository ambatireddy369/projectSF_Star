{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Retrieval Chunk",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "source_id",
    "title",
    "path",
    "domain",
    "chunk_kind",
    "source_trust",
    "official_source_ids",
    "skill_id",
    "text"
  ],
  "properties": {
    "id": {"type": "string"},
    "source_id": {"type": "string"},
    "title": {"type": "string"},
    "path": {"type": "string"},
    "domain": {"type": ["string", "null"]},
    "chunk_kind": {"type": "string"},
    "source_trust": {"type": "string"},
    "official_source_ids": {
      "type": "array",
      "items": {"type": "string"}
    },
    "skill_id": {"type": ["string", "null"]},
    "text": {"type": "string", "minLength": 1},
    "tags": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
